# Kast — environment variables
# Copy to .env and fill in any values you want to override.
# All variables are optional — sensible defaults are applied at startup.

# ── Server ────────────────────────────────────────────────────────────────────

# Publicly reachable URL of the Kast server (used in generated HLS playlist URLs).
# Set this to your domain or public IP so streams work from outside the host.
# Example: https://radio.example.com  or  http://203.0.113.10:8080
KAST_PUBLIC_URL=

# Admin API key — leave empty to auto-generate a random one on first run.
# The generated key is printed to the server log on startup.
# You can also enter it later in Dashboard → Settings → Connection.
KAST_API_KEY=

# JWT signing secret — leave empty to auto-generate.
KAST_JWT_SECRET=

# CORS origin for the dashboard (single value).
# Only needed if you host the dashboard on a different domain/port than the server.
# Example: https://dashboard.example.com
KAST_CORS_ORIGINS=

# ── Dashboard ─────────────────────────────────────────────────────────────────

# Internal URL the Next.js server uses to proxy API requests to the backend.
# Use the Docker service name when running via docker compose (default below).
# Change only if you rename the server service or run it on a different port.
# API_URL=http://server:8080
